{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read", "Edit", "Write", "Grep", "Glob",
      "Bash(npm run *)", "Bash(npm test*)", "Bash(npm install*)", "Bash(npm ci*)",
      "Bash(npx vitest*)", "Bash(npx tsc*)", "Bash(npx eslint*)",
      "Bash(npx supabase db diff*)", "Bash(npx supabase functions serve*)",
      "Bash(git status*)", "Bash(git diff*)", "Bash(git log*)", "Bash(git add*)", "Bash(git commit*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(npx supabase functions deploy*)",
      "Bash(npx supabase db push*)"
    ],
    "deny": [
      "Read(./**/.env)", "Read(./**/.env.*)", "Read(./**/*secret*)", "Read(./**/*service*role*)",
      "Bash(curl *)", "Bash(wget *)", "Bash(rm -rf *)"
    ]
  },
  "env": { "MIO_PHASE": "A", "NODE_ENV": "development" }
}
